            Assert.isTrue(story.acceptanceCriteria.size() >= 5,
                'Should have at least 5 acceptance criteria');
            Assert.isTrue(story.acceptanceCriteria[0].startsWith('GIVEN'),
                'First criteria should start with GIVEN');
