@isTest
private class UserStoryGeneratorTest {

    @isTest
    static void testGenerateUserStories_Success() {
        UserStoryGenerator.UserStoryRequest request = createSampleRequest();

        Test.startTest();
        UserStoryGenerator.UserStoryResponse response =
            UserStoryGenerator.generateUserStories(request);
        Test.stopTest();

        Assert.isNotNull(response, 'Response should not be null');
        Assert.isNotNull(response.timestamp, 'Timestamp should be set');
        Assert.areEqual('AI Delivery Copilot', response.generatedBy, 'Generated by should be set');
        Assert.isNotNull(response.epic, 'Epic should be generated');
        Assert.isTrue(response.userStories.size() > 0, 'Should generate user stories');
        Assert.isTrue(response.totalStories > 0, 'Total stories should be set');
        Assert.isTrue(response.estimatedStoryPoints > 0, 'Story points should be calculated');
        Assert.isTrue(response.readyForJira, 'Should be ready for Jira');
    }

    @isTest
    static void testEpicGeneration() {
        UserStoryGenerator.UserStoryRequest request = createSampleRequest();

        Test.startTest();
        UserStoryGenerator.UserStoryResponse response =
            UserStoryGenerator.generateUserStories(request);
        Test.stopTest();

        UserStoryGenerator.Epic epic = response.epic;
        Assert.isNotNull(epic.epicId, 'Epic ID should be generated');
        Assert.isTrue(epic.epicId.startsWith('EPIC-'), 'Epic ID should have correct prefix');
        Assert.isNotNull(epic.title, 'Epic title should be set');
        Assert.isNotNull(epic.description, 'Epic description should be set');
        Assert.isNotNull(epic.businessValue, 'Business value should be assessed');
        Assert.isNotNull(epic.targetRelease, 'Target release should be set');
        Assert.isNotNull(epic.estimatedEffort, 'Estimated effort should be set');
        Assert.isTrue(epic.affectedPersonas.size() > 0, 'Affected personas should be listed');
    }

    @isTest
    static void testUserStoryGeneration_Count() {
        UserStoryGenerator.UserStoryRequest request = createSampleRequest();

        Test.startTest();
        UserStoryGenerator.UserStoryResponse response =
            UserStoryGenerator.generateUserStories(request);
        Test.stopTest();

        Assert.areEqual(6, response.userStories.size(), 'Should generate 6 user stories');
        Assert.areEqual(6, response.totalStories, 'Total stories count should match');
    }

    @isTest
    static void testUserStoryStructure() {
        UserStoryGenerator.UserStoryRequest request = createSampleRequest();

        Test.startTest();
        UserStoryGenerator.UserStoryResponse response =
            UserStoryGenerator.generateUserStories(request);
        Test.stopTest();

        for (UserStoryGenerator.UserStory story : response.userStories) {
            Assert.isNotNull(story.storyId, 'Story ID should be set');
            Assert.isTrue(story.storyId.startsWith('US-'), 'Story ID should have correct prefix');
            Assert.isNotNull(story.title, 'Story title should be set');
            Assert.isNotNull(story.asA, 'As a should be set');
            Assert.isNotNull(story.iWant, 'I want should be set');
            Assert.isNotNull(story.soThat, 'So that should be set');
            Assert.isNotNull(story.priority, 'Priority should be set');
            Assert.isTrue(story.storyPoints > 0, 'Story points should be positive');
        }
    }

