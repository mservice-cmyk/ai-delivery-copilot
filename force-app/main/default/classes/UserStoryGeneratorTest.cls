    @isTest
    static void testEpicIdUniqueness() {
        UserStoryGenerator.UserStoryRequest request = createSampleRequest();

        Test.startTest();
        UserStoryGenerator.UserStoryResponse response1 =
            UserStoryGenerator.generateUserStories(request);
        UserStoryGenerator.UserStoryResponse response2 =
            UserStoryGenerator.generateUserStories(request);
        Test.stopTest();

        Assert.areNotEqual(response1.epic.epicId, response2.epic.epicId,
            'Epic IDs should be unique');
    }

    @isTest
    static void testStoryIdUniqueness() {
        UserStoryGenerator.UserStoryRequest request = createSampleRequest();

        Test.startTest();
        UserStoryGenerator.UserStoryResponse response =
            UserStoryGenerator.generateUserStories(request);
        Test.stopTest();

        Set<String> storyIds = new Set<String>();
        for (UserStoryGenerator.UserStory story : response.userStories) {
            Assert.isFalse(storyIds.contains(story.storyId),
                'Story IDs should be unique: ' + story.storyId);
            storyIds.add(story.storyId);
        }
    }

    // Helper method
    private static UserStoryGenerator.UserStoryRequest createSampleRequest() {
        UserStoryGenerator.UserStoryRequest request = new UserStoryGenerator.UserStoryRequest();
        request.businessRequirement = 'customer self-service portal';
        request.persona = 'Customer Support Manager';
        request.businessProcess = 'case management';
        request.objects = new List<String>{'Case', 'Contact'};
        return request;
    }
}
