    @isTest
    static void testStoryPointsCalculation() {
        UserStoryGenerator.UserStoryRequest request = createSampleRequest();

        Test.startTest();
        UserStoryGenerator.UserStoryResponse response =
            UserStoryGenerator.generateUserStories(request);
        Test.stopTest();

        Integer manualTotal = 0;
        for (UserStoryGenerator.UserStory story : response.userStories) {
            manualTotal += story.storyPoints;
        }

        Assert.areEqual(manualTotal, response.estimatedStoryPoints,
            'Total story points should match sum of individual stories');
    }

    @isTest
    static void testPriorityDistribution() {
        UserStoryGenerator.UserStoryRequest request = createSampleRequest();

        Test.startTest();
        UserStoryGenerator.UserStoryResponse response =
            UserStoryGenerator.generateUserStories(request);
        Test.stopTest();

        Set<String> priorities = new Set<String>();
        for (UserStoryGenerator.UserStory story : response.userStories) {
            priorities.add(story.priority);
        }

        Assert.isTrue(priorities.contains('High') || priorities.contains('Critical'),
            'Should have high priority stories');
    }

    @isTest
    static void testDifferentBusinessRequirements() {
        UserStoryGenerator.UserStoryRequest request1 = createSampleRequest();
        request1.businessRequirement = 'customer portal';

        UserStoryGenerator.UserStoryRequest request2 = createSampleRequest();
        request2.businessRequirement = 'automated revenue tracking';

        Test.startTest();
        UserStoryGenerator.UserStoryResponse response1 =
            UserStoryGenerator.generateUserStories(request1);
        UserStoryGenerator.UserStoryResponse response2 =
            UserStoryGenerator.generateUserStories(request2);
        Test.stopTest();

        Assert.isNotNull(response1.epic.businessValue, 'Business value should be assessed');
        Assert.isNotNull(response2.epic.businessValue, 'Business value should be assessed');
    }

    @isTest
    static void testMultipleObjects() {
        UserStoryGenerator.UserStoryRequest request = createSampleRequest();
        request.objects = new List<String>{'Account', 'Contact', 'Opportunity', 'Case'};

        Test.startTest();
        UserStoryGenerator.UserStoryResponse response =
            UserStoryGenerator.generateUserStories(request);
        Test.stopTest();

        Assert.areEqual(6, response.userStories.size(), 'Should generate stories regardless of object count');
    }

    @isTest
    static void testDifferentPersonas() {
        List<String> personas = new List<String>{
            'Sales Manager', 'Customer Support Agent', 'System Administrator',
            'Marketing Manager', 'Executive'
        };

        Test.startTest();
        for (String persona : personas) {
            UserStoryGenerator.UserStoryRequest request = createSampleRequest();
            request.persona = persona;

            UserStoryGenerator.UserStoryResponse response =
                UserStoryGenerator.generateUserStories(request);

            Assert.isNotNull(response, 'Response should be generated for ' + persona);
            Assert.isTrue(response.userStories.size() > 0,
                'Should generate stories for ' + persona);
        }
        Test.stopTest();
    }

    @isTest
    static void testJiraReadiness() {
        UserStoryGenerator.UserStoryRequest request = createSampleRequest();

        Test.startTest();
        UserStoryGenerator.UserStoryResponse response =
            UserStoryGenerator.generateUserStories(request);
        Test.stopTest();

        Assert.areEqual(true, response.readyForJira, 'Stories should be Jira-ready');

        // Verify Jira-ready format
        for (UserStoryGenerator.UserStory story : response.userStories) {
            // Has story ID
            Assert.isNotNull(story.storyId, 'Story ID required for Jira');

            // Has standard user story format
            Assert.isNotNull(story.asA, 'As a required for Jira');
            Assert.isNotNull(story.iWant, 'I want required for Jira');
            Assert.isNotNull(story.soThat, 'So that required for Jira');

            // Has essential fields
            Assert.isNotNull(story.priority, 'Priority required for Jira');
            Assert.isTrue(story.storyPoints > 0, 'Story points required for Jira');
            Assert.isTrue(story.acceptanceCriteria.size() > 0, 'AC required for Jira');
        }
    }

    @isTest
    static void testConfidenceScore() {
        UserStoryGenerator.UserStoryRequest request = createSampleRequest();

        Test.startTest();
        UserStoryGenerator.UserStoryResponse response =
            UserStoryGenerator.generateUserStories(request);
        Test.stopTest();

        Assert.isNotNull(response.confidenceScore, 'Confidence score should be set');
        Assert.isTrue(response.confidenceScore >= 0 && response.confidenceScore <= 100,
            'Confidence score should be between 0 and 100');
        Assert.isTrue(response.confidenceScore >= 80, 'Should have high confidence');
    }

